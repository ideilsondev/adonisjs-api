# ═══════════════════════════════════════════════════════════════════
# .env.example — template for every environment
#
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# Node / Runtime
# ─────────────────────────────────────────────
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development          # development | production | test
LOG_LEVEL=info                # trace | debug | info | warn | error | fatal

# ─────────────────────────────────────────────
# App
# Generate a secure key with: node ace generate:key
# Changing this key invalidates all signed URLs and encrypted cookies.
# ─────────────────────────────────────────────
APP_KEY=
APP_URL=http://localhost:3333

# ─────────────────────────────────────────────
# Session
# Options: cookie | memory | database | redis
#
# Recommended per environment:
#   development → redis  (or cookie for zero-deps)
#   test        → memory (no external service needed)
#   production  → redis  (shared across instances)
# ─────────────────────────────────────────────
SESSION_DRIVER=redis

# ─────────────────────────────────────────────
# CORS — Production allowed origins
#
# Comma-separated, fully-qualified origins.
# Only applied when NODE_ENV=production.
# In development every origin is allowed automatically.
#
# Example: https://app.example.com,https://admin.example.com
# Leave empty to block ALL cross-origin requests (safest default).
# ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=

# ─────────────────────────────────────────────
# Database (PostgreSQL)
#
# Security checklist:
#   ✓ Use a dedicated user with minimal privileges (not postgres/root)
#   ✓ Restrict DB_HOST to localhost or a private network CIDR
#   ✓ Enable SSL in production (add ?ssl=true to the connection string)
# ─────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=                  # REQUIRED — never leave blank in any environment
DB_DATABASE=zabe_db

# ─────────────────────────────────────────────
# Redis (Valkey / Redis-compatible)
#
# Used for: sessions, rate limiting
#
# Security checklist:
#   ✓ Always set a strong password (requirepass in redis.conf)
#   ✓ Bind Redis to 127.0.0.1 if on the same host as the app
#   ✓ Disable dangerous commands (FLUSHALL, CONFIG, DEBUG) in production
# ─────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=               # Strongly recommended in all environments
