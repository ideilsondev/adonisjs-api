# ─────────────────────────────────────────────
# Test environment — loaded automatically by
# "node ace test" when NODE_ENV=test
# ─────────────────────────────────────────────

# Node / Runtime
TZ=UTC
PORT=3334
HOST=localhost
NODE_ENV=test
LOG_LEVEL=error

# App
APP_KEY=zW5A4d42PUJ2MssuMReJ4-jGvFG1av5i
APP_URL=http://localhost:3334

# Session — use memory so tests need no Redis
SESSION_DRIVER=memory

# CORS — irrelevant in tests, left empty intentionally
CORS_ALLOWED_ORIGINS=

# Database — same instance, isolated via transactions
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=devpass
DB_DATABASE=zabe_db

# Redis — not used in tests (limiter uses memory store)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=devpass
